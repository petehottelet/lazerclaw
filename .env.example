# S3 Storage (required for asset hosting)
VITE_S3_BUCKET=your-s3-bucket-name
VITE_S3_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App origin for CORS (used by scripts/setup-s3.mjs)
APP_ORIGIN=https://your-app.vercel.app

# Authentication
JWT_SECRET=change-me-to-a-secure-random-string

# Admin login (frontend)
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=change-me

# Admin seed user (backend)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_NAME=Admin

# AI Design Assistant (Drunk Robot Lobster chatbot)
ANTHROPIC_API_KEY=

# AI Image Generation (Nano Banana API)
NANO_BANANA_API_KEY=

# Gemini Multimodal Chat (NanaBanana Chatbot)
GEMINI_API_KEY=

# Studio sync (optional)
STUDIO_BASE_URL=
STUDIO_ADMIN_KEY=

# Asset paths for upload script (scripts/upload-s3.mjs)
ASSETS_ROOT=./assets
CLIPART_ROOT=./clipart
